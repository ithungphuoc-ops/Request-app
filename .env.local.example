# SSO app tổng (account.hpcore.vn) — service account project "hpcons-portal".
# Xin lại từ Firebase Console (hpcons-portal > Project settings > Service accounts)
# hoặc từ Sếp nếu đã dùng cho ITAsset/pkd_crm-next.
HPCORE_FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Firebase project riêng của base-request-app (Firestore nghiệp vụ: groups/categories/requests).
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
